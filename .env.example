APP_NAME=Aastrika Sphere Search Service
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
API_PREFIX=/api/v1
SCHEMA_VERSION=1.0.0
API_KEY_HEADER_NAME=X-API-Key
API_KEYS=dev-search-key
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=1048576
MAX_AUDIO_UPLOAD_BYTES=5242880
SAFE_ERROR_MODE=true
BOOTSTRAP_SAMPLE_DATA=true
SAMPLE_DATA_PATH=sample_data/courses.json
SEARCH_BACKEND=inmemory
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=aastrika-courses-v1
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_TIMEOUT_SECONDS=10
ENABLE_SEMANTIC_SEARCH=true
ENABLE_INDIC_TRANSLITERATION=true
ENABLE_DEBUG_PAYLOADS=true
STT_PROVIDER=mock
VOICE_MOCK_ENABLED=true
WHISPER_MODEL_NAME=tiny
WHISPER_COMPUTE_TYPE=int8
WHISPER_DOWNLOAD_ROOT=.cache/whisper
WHISPER_LANGUAGE=
ANALYTICS_ENABLED=true
ANALYTICS_DB_PATH=data/analytics.db
MAX_QUERY_LENGTH=240
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=25
AUTOCORRECT_CONFIDENCE_THRESHOLD=0.90
SHOW_RESULTS_FOR_CONFIDENCE_THRESHOLD=0.96
DID_YOU_MEAN_SIMILARITY_CEILING=0.985
MIN_CANDIDATE_SCORE=0.35
SEMANTIC_RESCUE_THRESHOLD=0.28
FUZZY_RESCUE_THRESHOLD=0.78
